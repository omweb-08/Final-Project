PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/fabritech?retryWrites=true&w=majority

# Admin credentials (dev/test). For production, use stronger secrets
ADMIN_USER=admin
ADMIN_PASS=your_admin_password_here

# Email (SMTP) settings for Nodemailer (example: Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_email_app_password_or_smtp_password

# Where notification emails should be sent (your email)
ADMIN_EMAIL=youremail@gmail.com

# Session secret
SESSION_SECRET=someVeryStrongSecretString
